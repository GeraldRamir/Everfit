generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Plan {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  longDesc    String
  price       Float
  duration    String
  level       String
  features    String
  image       String?
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Recipe {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  description  String
  ingredients  String
  instructions String
  calories     Int
  protein      Int
  carbs        Int
  fat          Int
  prepTime     String
  servings     Int      @default(1)
  category     String
  image        String?
  featured     Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String
  content   String
  rating    Int      @default(5)
  image     String?
  createdAt DateTime @default(now())
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String
  content     String
  category    String
  image       String?
  publishedAt DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  createdAt DateTime @default(now())
}

model Service {
  id          String @id @default(cuid())
  title       String
  description String
  icon        String
  order       Int    @default(0)
}

model Challenge {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  duration    String
  price       Float    @default(0)
  image       String?
  featured    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}
